# Copy this file to .env and fill in your values.

# Gemini API Key — get one at https://aistudio.google.com/app/apikey
# Required for the enhanced /translate and /translate-and-compile features
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API token — get one free at https://huggingface.co/settings/tokens
# Required for /translate and /translate-and-compile endpoints (uses Mistral-7B)
# Required for /generate-assets endpoint (uses Stable Diffusion v1-5)
HF_API_TOKEN=your_huggingface_token_here

# Stripe — get keys at https://dashboard.stripe.com/apikeys
# Required for /checkout endpoint (billing)
STRIPE_SECRET_KEY=sk_test_...

# Stripe Price IDs — create products at https://dashboard.stripe.com/products
# Set billing interval to "monthly" for each tier
STRIPE_PRICE_CREATOR=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EDU=price_...

# ── Auth / Admin ──────────────────────────────────────────
# Secret key for JWT token signing (change this in production!)
JWT_SECRET=your-very-secret-jwt-key-change-me

# Admin secret key for accessing admin dashboard & API
ADMIN_SECRET_KEY=your-admin-secret-key

# SMTP settings for sending OTP emails
# For Gmail: enable "App Passwords" in your Google Account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@example.com
