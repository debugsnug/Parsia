# Copy this file to .env and fill in your values.

# Gemini API Key — get one at https://aistudio.google.com/app/apikey
# Required for /translate and /translate-and-compile
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face API token — get one at https://huggingface.co/settings/tokens
# Required only for /generate-assets endpoint
HF_API_TOKEN=your_hf_api_token_here

# Stripe — get keys at https://dashboard.stripe.com/apikeys
# Required for /checkout endpoint (billing)
STRIPE_SECRET_KEY=sk_test_...

# Stripe Price IDs — create products at https://dashboard.stripe.com/products
# Set billing interval to "monthly" for each tier
STRIPE_PRICE_CREATOR=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_EDU=price_...

# ── Auth / Admin ──────────────────────────────────────────
# Secret key for JWT token signing
JWT_SECRET=replace_with_a_long_random_secret

# Admin secret key for accessing admin dashboard & API
ADMIN_SECRET_KEY=replace_with_a_long_random_admin_secret

# SMTP settings for sending OTP emails
# For Gmail: enable "App Passwords" in your Google Account
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASS=put key here
SMTP_FROM=noreply@example.com
